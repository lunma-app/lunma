{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm verify)",
      "Bash(pnpm exec tsc --noEmit)",
      "Bash(pnpm exec biome check *)",
      "Bash(pnpm exec biome format *)",
      "Bash(pnpm lint:styles)",
      "Bash(pnpm exec stylelint *)",
      "Bash(pnpm exec vitest *)",
      "Bash(pnpm test:run)",
      "Bash(pnpm test:e2e)",
      "Bash(pnpm check)",
      "Bash(pnpm exec svelte-check *)",
      "Bash(pnpm build)",
      "Bash(git status*)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch*)",
      "Bash(openspec list*)",
      "Bash(openspec status *)",
      "Bash(openspec validate *)",
      "Bash(openspec instructions *)",
      "Bash(mv openspec*)",
      "Bash(mkdir -p openspec/changes/archive)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push * --force*)",
      "Bash(git push * -f*)",
      "Bash(git push --mirror*)",
      "Bash(git reset --hard*)",
      "Bash(git rebase*)",
      "Bash(git filter-branch*)",
      "Bash(git reflog expire*)",
      "Bash(git update-ref -d*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/protect-openspec-archive.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/openspec-active.sh"
          }
        ]
      }
    ]
  }
}
