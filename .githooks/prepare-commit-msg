#!/usr/bin/env sh
# Auto-append DCO Signed-off-by if not already present.
# Skipped for merge commits, squash commits, and fixups (they inherit sign-off
# from the original or get it on merge).
set -eu

COMMIT_MSG_FILE="$1"
COMMIT_SOURCE="${2:-}"

case "$COMMIT_SOURCE" in
  merge|squash|commit) exit 0 ;;
esac

NAME=$(git config --get user.name || echo "")
EMAIL=$(git config --get user.email || echo "")

if [ -z "$NAME" ] || [ -z "$EMAIL" ]; then
  exit 0
fi

SIGNOFF="Signed-off-by: $NAME <$EMAIL>"

if ! grep -qF "$SIGNOFF" "$COMMIT_MSG_FILE"; then
  printf '\n%s\n' "$SIGNOFF" >> "$COMMIT_MSG_FILE"
fi
