{
  "manifest_version": 3,
  "name": "Lunma",
  "short_name": "Lunma",
  "version": "0.4.0",
  "description": "Vertical tabs and per-project Spaces for Chrome, with smart folders and a quick launcher.",
  "minimum_chrome_version": "123",
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "sidePanel",
    "alarms",
    "favicon",
    "scripting"
  ],
  "optional_permissions": [
    "bookmarks",
    "history"
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*/*",
        "http://*/*"
      ],
      "js": [
        "src/launcher/overlay.ts"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://*/*",
        "http://*/*"
      ],
      "js": [
        "src/content/tab-boundary.ts"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "fonts/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    },
    {
      "resources": [
        "_favicon/*"
      ],
      "matches": [
        "<all_urls>"
      ],
      "use_dynamic_url": true
    }
  ],
  "side_panel": {
    "default_path": "src/sidebar/index.html"
  },
  "chrome_url_overrides": {
    "newtab": "src/launcher/newtab/index.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Open Lunma sidebar",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "commands": {
    "pin-active-tab": {
      "suggested_key": {
        "default": "Alt+P",
        "mac": "Alt+D"
      },
      "description": "Pin the active tab to the current Space"
    },
    "toggle-launcher": {
      "suggested_key": {
        "default": "Alt+L",
        "mac": "Alt+L"
      },
      "description": "Toggle the Lunma launcher overlay"
    }
  },
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  }
}
