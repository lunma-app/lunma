{
  "name": "@lunma/extension",
  "version": "0.4.3",
  "license": "Apache-2.0",
  "private": true,
  "description": "Lunma: spatial tab and bookmark management for Chrome (MV3 extension)",
  "type": "module",
  "scripts": {
    "dev": "pnpm gen:icons && pnpm gen:i18n && vite",
    "build": "pnpm gen:icons && pnpm gen:i18n && vite build",
    "gen:icons": "node scripts/gen-icon-loaders.mjs",
    "gen:i18n": "paraglide-js compile --project ./project.inlang --outdir ./src/shared/paraglide --strategy custom-lunmaSettings baseLocale --no-emit-git-ignore --emit-ts-declarations",
    "gen:app-icons": "node scripts/gen-app-icons.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "pnpm build && playwright test",
    "lint:styles": "stylelint 'src/**/*.{svelte,css}'",
    "catalog": "vite --config vite.catalog.config.ts",
    "catalog:build": "vite build --config vite.catalog.config.ts",
    "typecheck:catalog": "tsc --noEmit -p tsconfig.catalog.json",
    "lint:catalog": "biome check catalog",
    "check:catalog": "svelte-check --tsconfig ./tsconfig.catalog.json",
    "lint:styles:catalog": "stylelint 'catalog/**/*.{svelte,css}'",
    "verify:catalog": "pnpm typecheck:catalog && pnpm lint:catalog && pnpm check:catalog && pnpm lint:styles:catalog",
    "pack": "pnpm build && cd dist && zip -r ../extension.zip .",
    "verify": "pnpm typecheck && pnpm lint && pnpm check && pnpm lint:styles && pnpm verify:catalog && pnpm test:run"
  },
  "dependencies": {
    "@leeoniya/ufuzzy": "1.0.19",
    "@lucide/svelte": "^1.21.0",
    "@lunma/tokens": "workspace:*",
    "bits-ui": "^2.18.1",
    "saxes": "6.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.7.0",
    "@inlang/paraglide-js": "catalog:",
    "@playwright/test": "^1.61.1",
    "@sveltejs/vite-plugin-svelte": "catalog:",
    "@testing-library/svelte": "^5.4.2",
    "@types/chrome": "^0.2.0",
    "@types/culori": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "^4.1.9",
    "culori": "catalog:",
    "jsdom": "catalog:",
    "postcss-html": "^1.8.1",
    "shiki": "^4.3.0",
    "stylelint": "^17.13.0",
    "stylelint-declaration-strict-value": "^1.11.1",
    "svelte": "catalog:",
    "svelte-check": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
