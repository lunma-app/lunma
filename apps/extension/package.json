{
  "name": "@lunma/extension",
  "version": "0.0.0",
  "license": "Apache-2.0",
  "private": true,
  "description": "Lunma — spatial tab and bookmark management for Chrome (MV3 extension)",
  "type": "module",
  "scripts": {
    "dev": "pnpm gen:icons && vite",
    "build": "pnpm gen:icons && vite build",
    "gen:icons": "node scripts/gen-icon-loaders.mjs",
    "gen:app-icons": "node scripts/gen-app-icons.mjs",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "pnpm build && playwright test",
    "lint:styles": "stylelint 'src/**/*.{svelte,css}'",
    "pack": "pnpm build && cd dist && zip -r ../extension.zip .",
    "verify": "tsc --noEmit && biome check src && pnpm check && pnpm lint:styles && vitest run"
  },
  "dependencies": {
    "@lucide/svelte": "^1.16.0",
    "@lunma/tokens": "workspace:*",
    "bits-ui": "^2.18.1",
    "saxes": "6.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@playwright/test": "^1.60.0",
    "@sveltejs/vite-plugin-svelte": "catalog:",
    "@testing-library/svelte": "^5.3.1",
    "@types/chrome": "^0.1.42",
    "@types/culori": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "^4.1.7",
    "culori": "catalog:",
    "jsdom": "catalog:",
    "postcss-html": "^1.8.1",
    "stylelint": "^17.12.0",
    "stylelint-declaration-strict-value": "^1.11.1",
    "svelte": "catalog:",
    "svelte-check": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
