  "license": "Apache-2.0",
  "private": true,
  "description": "Lunma marketing site: the static landing page at lunma.app",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync",
