    "@types/culori": "catalog:",
    "@types/node": "catalog:",
    "culori": "catalog:",
    "jsdom": "catalog:",
    "simple-icons": "16.23.0",
    "svelte": "catalog:",
    "svelte-check": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
