{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "src/**/*.{ts,js,svelte}",
      "*.{ts,js,json}",
      "!**/dist",
      "!**/.devbox",
      "!**/node_modules"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noEmptyBlockStatements": "error",
        "noImportCycles": "error"
      }
    }
  },
  "overrides": [
    {
      "includes": [
        "**/*.svelte"
      ],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedVariables": "off",
            "noUnusedImports": "off"
          }
        }
      }
    },
    {
      "includes": [
        "src/shared/**"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "**/ui/**",
                      "**/background/**",
                      "**/sidebar/**",
                      "**/launcher/**",
                      "**/options/**",
                      "**/content/**"
                    ]
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": [
        "src/ui/**"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "**/background/**",
                      "**/sidebar/**",
                      "**/launcher/**",
                      "**/options/**",
                      "**/content/**"
                    ]
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": [
        "src/background/**"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "**/ui/**",
                      "**/sidebar/**",
                      "**/options/**",
                      "**/content/**",
                      "**/launcher/**",
                      "!**/launcher/shared/**"
                    ]
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": [
        "src/sidebar/**"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "**/background/**",
                      "**/launcher/**",
                      "**/options/**",
                      "**/content/**"
                    ]
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": [
        "src/options/**"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "**/background/**",
                      "**/sidebar/**",
                      "**/launcher/**",
                      "**/content/**"
                    ]
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": [
        "src/launcher/**"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "**/background/**",
                      "**/sidebar/**",
                      "**/options/**",
                      "**/content/**"
                    ]
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": [
        "src/content/**"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "**/ui/**",
                      "**/background/**",
                      "**/sidebar/**",
                      "**/launcher/**",
                      "**/options/**"
                    ]
                  }
                ]
              }
            }
          }
        }
      }
    }
  ],
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  }
}
