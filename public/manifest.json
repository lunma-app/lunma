{
  "manifest_version": 3,
  "name": "Lunma",
  "short_name": "Lunma",
  "version": "0.0.0",
  "description": "Spatial tab and bookmark management for Chrome.",
  "minimum_chrome_version": "123",
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "sidePanel",
    "alarms",
    "favicon",
    "bookmarks",
    "history",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/launcher/overlay.ts"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/tab-boundary.ts"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "fonts/*",
        "_favicon/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "side_panel": {
    "default_path": "src/sidebar/index.html"
  },
  "chrome_url_overrides": {
    "newtab": "src/launcher/newtab/index.html"
  },
  "action": {
    "default_title": "Open Lunma sidebar"
  },
  "commands": {
    "pin-active-tab": {
      "suggested_key": {
        "default": "Alt+D",
        "mac": "Alt+D"
      },
      "description": "Pin the active tab to the current Space"
    },
    "toggle-launcher": {
      "suggested_key": {
        "default": "Alt+L",
        "mac": "Alt+L"
      },
      "description": "Toggle the Lunma launcher overlay"
    }
  },
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  }
}
