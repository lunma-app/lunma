.DS_Store
node_modules/
dist/
apps/site/build/

# Brand fonts are sourced once from packages/tokens/fonts and copied into each
# app's served root at build — never committed a second time.
apps/extension/public/fonts/
apps/extension/catalog/public/fonts/
apps/site/static/fonts/

# Catalog controls derived from src/ui Props interfaces at config-load time —
# never committed, regenerated on every `catalog`/`catalog:build` run.
apps/extension/catalog/lib/derived-controls.generated.ts

.devbox/
.svelte-kit/
.vite/
coverage/
playwright-report/
test-results/
.playwright-mcp/
*.log
.env
.env.*
!.env.example

# Transient Claude Code harness artifact (runtime scheduler lock)
.claude/scheduled_tasks.lock
# Per-machine agent memory state
.claude/memory/
# Local planning scratch (superseded by openspec/changes/)
.claude/plans/

# Release artifacts (root-level output of the /release skill)
/release/

# Claude Code worktrees
.claude/worktrees/
